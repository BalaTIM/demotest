        async function appendDynamicSuggestions(query, messageRowElement) {
            if (!query) return;

            // Simple NLP to extract core context for dynamic searches
            const stopWords = ['what','is','how','to','explain','write','a','the','for','in','of','and','draft','can','you','help','me','with','make','create','some'];
            const words = query.toLowerCase().split(/[\s,?\.]+/).filter(w => w.length > 2 && !stopWords.includes(w));
            const keyword = words.slice(0, 3).join(' ') || "technology"; // fallback
            const encodedKeyword = encodeURIComponent(keyword);

            const wrap = document.createElement('div');
            wrap.className = 'suggestions-wrapper';
            messageRowElement.appendChild(wrap);

            // 1. DYNAMIC VIDEOS (CSS Generated Thumbnails + YouTube Search Links)
            if (document.getElementById('toggle-videos').checked) {
                // Generate a pseudo-random hash from keyword to give unique colors per topic
                const hash = Array.from(keyword).reduce((acc, char) => acc + char.charCodeAt(0), 0);
                const hue1 = hash % 360;
                const hue2 = (hue1 + 40) % 360;

                const videoSection = document.createElement('div');
                videoSection.className = 'suggestion-section';
                videoSection.innerHTML = `
                    <h4><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg> Video Results</h4>
