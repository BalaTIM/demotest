<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chots - AI Intelligence</title>
    <!-- Modern Font: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        :root {
            --bg-color: #ffffff;
            --text-primary: #111827;
            --text-secondary: #4b5563;
            --text-placeholder: #9ca3af;
            --icon-color: #374151;
            --icon-hover-bg: #f3f4f6;
            --input-bg: #f9fafb;
            --input-border: #e5e7eb;
            --avatar-color: #10a37f;
            --user-bubble-bg: #f3f4f6;
            --code-header-bg: #f9fafb;
            --code-bg: #ffffff;
            --border-light: #e5e7eb;
            --accent-blue: #3b82f6;
            --accent-green: #10a37f;
            --panel-bg: #f9fafb;
            --left-panel-width: 280px;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            --radius-md: 0.5rem;
            --radius-lg: 0.75rem;
            --radius-xl: 1rem;
            --radius-2xl: 1.5rem;
        }

        /* Dark Mode Variables */
        body.dark-mode {
            --bg-color: #171717;
            --text-primary: #ececec;
            --text-secondary: #a1a1aa;
            --text-placeholder: #52525b;
            --icon-color: #ececec;
            --icon-hover-bg: #27272a;
            --input-bg: #27272a;
            --input-border: #3f3f46;
            --user-bubble-bg: #27272a;
            --code-header-bg: #1e1e1e;
            --code-bg: #0f0f0f;
            --border-light: #3f3f46;
            --panel-bg: #1f1f1f;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.5);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.4);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; outline: none; }

        /* Hide scrollbars for main containers */
        .left-panel-inner::-webkit-scrollbar, .chat-scroll-area::-webkit-scrollbar, 
        .landing-page::-webkit-scrollbar, .dropdown-menu::-webkit-scrollbar, 
        .quick-prompts::-webkit-scrollbar, .suggestions-grid::-webkit-scrollbar { display: none; }
        
        .left-panel-inner, .chat-scroll-area, .landing-page, .dropdown-menu, .quick-prompts, .suggestions-grid {
            -ms-overflow-style: none; scrollbar-width: none;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color); color: var(--text-primary);
            height: 100vh; width: 100vw; display: flex; overflow: hidden; font-size: 15px;
            -webkit-font-smoothing: antialiased; line-height: 1.6;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        /* Animations */
        @keyframes slideUpFade {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* ==================== LEFT PANEL ==================== */
        .left-panel {
            width: 0; height: 100%; background-color: var(--panel-bg);
            border-right: 1px solid var(--border-light); display: flex; flex-direction: column;
            overflow: hidden; transition: width 0.3s cubic-bezier(0.25, 1, 0.5, 1);
            flex-shrink: 0; z-index: 50;
        }
        .left-panel.open { width: var(--left-panel-width); }
        .left-panel-inner {
            width: var(--left-panel-width); min-width: var(--left-panel-width);
            flex: 1; display: flex; flex-direction: column;
            padding: 20px 16px; gap: 20px; overflow-y: auto;
        }

        .panel-header {
            display: flex; align-items: center; justify-content: space-between;
            padding-bottom: 12px;
        }
        .panel-title-wrapper { display: flex; align-items: center; gap: 10px; color: var(--text-primary); }
        .panel-title { font-size: 16px; font-weight: 600; letter-spacing: -0.01em; }
        
        .mobile-close-btn { display: none; background: transparent; border: none; color: var(--text-secondary); cursor: pointer; padding: 6px; border-radius: var(--radius-md); transition: all 0.2s; }
        .mobile-close-btn:hover { background: var(--icon-hover-bg); color: var(--text-primary); }

        /* New Chat Button */
        .new-chat-btn-sidebar {
            width: 100%; padding: 12px; background: var(--text-primary); color: var(--bg-color);
            border: none; border-radius: var(--radius-lg); font-size: 14px; font-weight: 500;
            display: flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer;
            transition: opacity 0.2s, transform 0.2s; box-shadow: var(--shadow-sm);
        }
        .new-chat-btn-sidebar:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: var(--shadow-md); }

        /* Sidebar Navigation Items */
        .sidebar-section { display: flex; flex-direction: column; gap: 4px; }
        .sidebar-title { font-size: 11px; font-weight: 600; color: var(--text-placeholder); text-transform: uppercase; letter-spacing: 0.05em; padding: 0 8px; margin-bottom: 4px; }
        .sidebar-item {
            display: flex; align-items: center; gap: 10px; padding: 10px 12px;
            border-radius: var(--radius-md); color: var(--text-secondary); text-decoration: none;
            font-size: 13px; font-weight: 500; transition: background 0.2s, color 0.2s; cursor: pointer;
            border: 1px solid transparent;
        }
        .sidebar-item:hover { background: var(--icon-hover-bg); color: var(--text-primary); }
        .sidebar-item.active { background: var(--icon-hover-bg); color: var(--text-primary); font-weight: 600; border-color: var(--border-light); }
        .sidebar-item svg { width: 16px; height: 16px; stroke-width: 2; flex-shrink: 0; }
        .sidebar-item-text { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; }
        .sidebar-badge { background: var(--accent-blue); color: #fff; font-size: 10px; padding: 2px 6px; border-radius: 12px; font-weight: 700; margin-left: auto; }

        /* Settings Card */
        .settings-card {
            background: var(--bg-color); border: 1px solid var(--border-light);
            border-radius: var(--radius-lg); padding: 16px; display: flex; flex-direction: column;
            gap: 12px; box-shadow: var(--shadow-sm); margin-top: 8px;
        }
        .settings-card h4 { font-size: 13px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; margin-bottom: 4px; display: flex; align-items: center; gap: 6px; }
        
        /* Toggle Switches */
        .toggle-row { display: flex; justify-content: space-between; align-items: center; font-size: 13px; font-weight: 500; color: var(--text-primary); }
        .switch { position: relative; display: inline-block; width: 34px; height: 18px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: var(--border-light); transition: .3s; border-radius: 20px; }
        .slider:before { position: absolute; content: ""; height: 12px; width: 12px; left: 3px; bottom: 3px; background-color: white; transition: .3s; border-radius: 50%; box-shadow: var(--shadow-sm); }
        input:checked + .slider { background-color: var(--accent-green); }
        input:checked + .slider:before { transform: translateX(16px); }

        /* Sidebar Footer */
        .sidebar-footer {
            width: var(--left-panel-width); min-width: var(--left-panel-width);
            padding: 16px; border-top: 1px solid var(--border-light); background: var(--panel-bg);
            display: flex; flex-direction: column; gap: 8px; z-index: 10;
        }
        .user-profile {
            display: flex; align-items: center; gap: 12px; padding: 8px; border-radius: var(--radius-md);
            cursor: pointer; transition: background 0.2s; margin-top: 4px;
        }
        .user-profile:hover { background: var(--icon-hover-bg); }
        .user-avatar { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #3b82f6, #8b5cf6); display: flex; align-items: center; justify-content: center; color: white; font-weight: 600; font-size: 14px; }
        .user-info { display: flex; flex-direction: column; }
        .user-name { font-size: 14px; font-weight: 600; color: var(--text-primary); }
        .user-plan { font-size: 11px; color: var(--text-secondary); font-weight: 500; }

        .sidebar-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0,0,0,0.5); z-index: 45; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; backdrop-filter: blur(2px); }
        .sidebar-overlay.active { opacity: 1; pointer-events: auto; }

        /* ==================== DROPDOWNS & TOP BAR ==================== */
        .model-dropdown-container { position: relative; z-index: 30; }
        .dropdown-menu {
            position: absolute; top: 100%; left: 0; margin-top: 8px;
            background-color: var(--bg-color); border: 1px solid var(--border-light);
            border-radius: var(--radius-lg); box-shadow: var(--shadow-lg);
            width: 260px; max-height: 400px; overflow-y: auto; display: none; padding: 6px;
        }
        .dropdown-menu.show { display: block; animation: fadeIn 0.2s ease; }
        .dropdown-item {
            display: flex; align-items: flex-start; gap: 12px; padding: 10px 12px;
            cursor: pointer; border-radius: var(--radius-md); font-size: 14px; color: var(--text-primary);
            transition: background-color 0.2s;
        }
        .dropdown-item:hover { background-color: var(--icon-hover-bg); }
        .dropdown-item .model-logo { width: 20px; height: 20px; margin-top: 2px; flex-shrink: 0; }
        .model-info { display: flex; flex-direction: column; line-height: 1.4; }
        .model-title { font-size: 14px; font-weight: 600; }
        .model-highlight { font-size: 12px; font-weight: 500; color: var(--text-secondary); margin-top: 2px; }
        .check-icon { margin-left: auto; opacity: 0; color: var(--text-primary); align-self: center; width: 16px; }
        .dropdown-item.selected .check-icon { opacity: 1; }

        .main-content { flex: 1; display: flex; flex-direction: column; position: relative; height: 100%; min-width: 0; }
        .top-bar { height: 60px; display: flex; justify-content: space-between; align-items: center; padding: 0 20px; position: sticky; top: 0; background: var(--bg-color); border-bottom: 1px solid transparent; z-index: 20; transition: all 0.3s ease; }
        .top-bar.scrolled { border-bottom: 1px solid var(--border-light); box-shadow: var(--shadow-sm); }

        .toggle-panel-btn {
            width: 40px; height: 40px; border-radius: var(--radius-md); border: none;
            background: transparent; display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: all 0.2s; color: var(--text-secondary); margin-right: 8px;
        }
        .toggle-panel-btn:hover { background-color: var(--icon-hover-bg); color: var(--text-primary); }
        
        .top-left { display: flex; align-items: center; }
        .model-selector { display: flex; align-items: center; gap: 6px; font-weight: 600; font-size: 16px; color: var(--text-primary); cursor: pointer; padding: 8px 12px; border-radius: var(--radius-md); transition: all 0.2s; }
        .model-selector:hover { background-color: var(--icon-hover-bg); }
        .model-version { color: var(--text-placeholder); font-weight: 500; font-size: 14px; }

        .top-right-actions { display: flex; align-items: center; gap: 6px; }
        .icon-btn { width: 40px; height: 40px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s ease; border: none; background: transparent; color: var(--text-secondary); }
        .icon-btn:hover { background-color: var(--icon-hover-bg); color: var(--text-primary); }
        .share-btn { display: flex; align-items: center; gap: 8px; padding: 8px 14px; border: 1px solid var(--border-light); border-radius: var(--radius-md); font-size: 13px; font-weight: 600; background: var(--bg-color); cursor: pointer; transition: all 0.2s; color: var(--text-primary); box-shadow: var(--shadow-sm); }
        .share-btn:hover { background-color: var(--icon-hover-bg); box-shadow: none; }

        /* ==================== CHAT AREA ==================== */
        .chat-scroll-area { flex: 1; overflow-y: auto; padding-top: 24px; padding-bottom: 180px; scroll-behavior: smooth; width: 100%; }
        .conversation-width { max-width: 800px; margin: 0 auto; padding: 0 24px; width: 100%; }

        .message-row { display: flex; margin-bottom: 32px; width: 100%; flex-direction: column; animation: slideUpFade 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .message-row.user { align-items: flex-end; }
        .message-row.assistant { align-items: flex-start; }

        .user-bubble { background-color: var(--user-bubble-bg); padding: 14px 20px; border-radius: var(--radius-xl); border-bottom-right-radius: 4px; max-width: 80%; font-size: 15px; line-height: 1.6; color: var(--text-primary); font-weight: 400; white-space: pre-wrap; word-wrap: break-word; box-shadow: var(--shadow-sm); }
        
        .assistant-response { width: 100%; font-size: 15.5px; line-height: 1.75; color: var(--text-primary); }
        .assistant-response strong { font-weight: 600; }
        .assistant-response p { margin-bottom: 16px; }
        .assistant-response p:last-child { margin-bottom: 0; }
        .assistant-response ul, .assistant-response ol { margin-bottom: 16px; padding-left: 24px; }
        .assistant-response li { margin-bottom: 8px; }
        .assistant-response h1, .assistant-response h2, .assistant-response h3 { margin-top: 24px; margin-bottom: 16px; font-weight: 700; color: var(--text-primary); line-height: 1.3; }
        .assistant-response a { color: var(--accent-blue); text-decoration: none; font-weight: 500; }
        .assistant-response a:hover { text-decoration: underline; }
        .assistant-response blockquote { border-left: 4px solid var(--border-light); padding-left: 16px; color: var(--text-secondary); margin-bottom: 16px; font-style: italic; background: var(--input-bg); padding: 12px 16px; border-radius: 0 var(--radius-md) var(--radius-md) 0; }
        
        /* Timestamps */
        .msg-timestamp { font-size: 11px; color: var(--text-placeholder); margin-top: 6px; font-weight: 500; }
        .message-row.user .msg-timestamp { text-align: right; padding-right: 4px; }
        .message-row.assistant .msg-timestamp { text-align: left; padding-left: 4px; margin-bottom: 8px;}

        /* Smart Actions & Action Bar */
        .message-actions { display: flex; gap: 6px; margin-top: 12px; opacity: 0; transition: opacity 0.3s ease; flex-wrap: wrap; }
        .message-row.assistant:hover .message-actions { opacity: 1; }
        .msg-action-btn { background: var(--bg-color); border: 1px solid var(--border-light); cursor: pointer; padding: 6px 10px; border-radius: var(--radius-md); color: var(--text-secondary); display: flex; align-items: center; justify-content: center; gap: 6px; font-size: 12px; font-weight: 600; transition: all 0.2s; box-shadow: var(--shadow-sm); }
        .msg-action-btn:hover { background-color: var(--icon-hover-bg); color: var(--text-primary); border-color: #d1d5db; }
        .msg-action-btn svg { width: 14px; height: 14px; stroke-width: 2.2; }

        /* Code Blocks */
        code:not(pre code) { background-color: var(--icon-hover-bg); padding: 3px 6px; border-radius: 6px; font-family: 'SF Mono', 'Consolas', monospace; font-size: 0.9em; color: var(--text-primary); border: 1px solid var(--border-light); }
        .code-block { border: 1px solid var(--border-light); border-radius: var(--radius-lg); margin: 20px 0; overflow: hidden; background: var(--code-bg); box-shadow: var(--shadow-sm); }
        .code-header { background-color: var(--code-header-bg); padding: 10px 16px; font-size: 12px; font-weight: 600; color: var(--text-secondary); display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-light); font-family: 'Inter', sans-serif; }
        .copy-btn { display: flex; align-items: center; gap: 6px; background: none; border: none; cursor: pointer; color: var(--text-secondary); font-size: 12px; font-weight: 500; transition: color 0.2s; }
        .copy-btn:hover { color: var(--text-primary); }
        .code-content { padding: 16px; overflow-x: auto; font-family: 'SF Mono', 'Consolas', monospace; font-size: 14px; line-height: 1.5; color: var(--text-primary); }

        /* ==================== DYNAMIC SUGGESTIONS UI ==================== */
        .suggestions-wrapper { margin-top: 24px; padding-top: 20px; border-top: 1px dashed var(--border-light); animation: fadeIn 0.5s ease; width: 100%; }
        .suggestion-section { margin-bottom: 24px; }
        .suggestion-section h4 { font-size: 13px; font-weight: 600; color: var(--text-secondary); margin-bottom: 12px; display: flex; align-items: center; gap: 6px; text-transform: uppercase; letter-spacing: 0.05em; }
        .suggestion-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px; width: 100%; }
        
        .suggestion-card { background: var(--bg-color); border: 1px solid var(--border-light); border-radius: var(--radius-lg); overflow: hidden; display: flex; flex-direction: column; text-decoration: none; transition: all 0.2s ease; box-shadow: var(--shadow-sm); position: relative; }
        .suggestion-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: var(--text-placeholder); }
        
        /* Dynamic Video Card */
        .video-card .dynamic-thumb { width: 100%; height: 120px; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 18px; text-transform: capitalize; text-align: center; padding: 10px; line-height: 1.2; }
        .video-card .play-icon { position: absolute; top: 40px; left: 50%; transform: translateX(-50%); width: 44px; height: 44px; background: rgba(0,0,0,0.5); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; backdrop-filter: blur(2px); transition: background 0.2s; }
        .video-card:hover .play-icon { background: rgba(255, 0, 0, 0.8); } /* YouTube red on hover */
        .video-card .play-icon svg { width: 22px; height: 22px; fill: currentColor; margin-left: 2px;}
        .card-content { padding: 12px; display: flex; flex-direction: column; gap: 4px; }
        .card-title { font-size: 13px; font-weight: 600; color: var(--text-primary); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        .card-desc { font-size: 12px; color: var(--text-secondary); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        
        /* Link Card */
        .link-card { padding: 16px; justify-content: center; border-left: 3px solid var(--accent-blue); }
        .link-card .card-icon { color: var(--accent-blue); margin-bottom: 8px; }

        /* Image Card */
        .image-card img { width: 100%; height: 160px; object-fit: cover; transition: transform 0.3s; display: block; }
        .image-card:hover img { transform: scale(1.05); }

        /* Smart Utility Box */
        .smart-utility-box { margin-top: 16px; background: linear-gradient(to right, var(--input-bg), var(--bg-color)); border: 1px solid var(--border-light); border-radius: var(--radius-lg); padding: 16px; display: flex; align-items: center; justify-content: space-between; box-shadow: var(--shadow-sm); animation: slideUpFade 0.4s ease forwards; }
        .smart-utility-info { display: flex; align-items: center; gap: 10px; font-weight: 600; font-size: 14px; color: var(--text-primary); }
        .smart-utility-info svg { color: var(--accent-blue); }
        .smart-btn { background: var(--text-primary); color: var(--bg-color); border: none; padding: 8px 16px; border-radius: var(--radius-md); font-size: 13px; font-weight: 600; cursor: pointer; transition: opacity 0.2s; }
        .smart-btn:hover { opacity: 0.9; }

        /* ==================== INPUT AREA ==================== */
        .input-area-fixed { position: fixed; bottom: 0; left: var(--left-panel-width, 0); right: 0; background: linear-gradient(180deg, rgba(255,255,255,0) 0%, var(--bg-color) 40%); padding-bottom: 24px; padding-top: 40px; z-index: 20; transition: left 0.3s cubic-bezier(0.25, 1, 0.5, 1); }
        body:not(.left-panel-open) .input-area-fixed { left: 0; }
        body.dark-mode .input-area-fixed { background: linear-gradient(180deg, rgba(23,23,23,0) 0%, var(--bg-color) 40%); }
        body:not(.chat-active) .input-area-fixed { position: relative; bottom: auto; left: auto; right: auto; background: transparent; padding: 32px 0 0 0; transition: none; }

        .input-wrapper { width: 100%; max-width: 800px; margin: 0 auto; padding: 0 24px; position: relative; }
        .input-box { background-color: var(--input-bg); border-radius: var(--radius-2xl); padding: 12px 16px 8px 16px; display: flex; flex-direction: column; gap: 8px; min-height: 60px; border: 1px solid var(--input-border); transition: all 0.3s ease; box-shadow: var(--shadow-sm); }
        .input-box:focus-within { border-color: #d1d5db; background-color: var(--bg-color); box-shadow: var(--shadow-md); }
        body.dark-mode .input-box:focus-within { border-color: #52525b; }

        .input-row { display: flex; justify-content: space-between; align-items: center; width: 100%; padding-top: 4px; }
        .toolbar-left { display: flex; align-items: center; gap: 8px; }
        .toolbar-right { display: flex; align-items: center; gap: 8px; }
        
        .text-input { flex: 1; width: 100%; background: transparent; border: none; font-size: 15px; color: var(--text-primary); resize: none; max-height: 200px; overflow-y: auto; font-family: inherit; line-height: 24px; padding: 4px 0; min-height: 32px; box-sizing: border-box; }
        .text-input::placeholder { color: var(--text-placeholder); font-weight: 400; }
        .text-input::-webkit-scrollbar { width: 4px; }
        .text-input::-webkit-scrollbar-thumb { background-color: var(--border-light); border-radius: 4px; }

        .action-btn { width: 36px; height: 36px; border-radius: 50%; background: transparent; display: flex; align-items: center; justify-content: center; cursor: pointer; border: none; color: var(--text-secondary); flex-shrink: 0; transition: all 0.2s; }
        .action-btn:hover { background-color: var(--border-light); color: var(--text-primary); }
        
        .voice-mode-btn { background-color: var(--text-primary); color: var(--bg-color); }
        .voice-mode-btn:hover { opacity: 0.9; background-color: var(--text-primary); color: var(--bg-color); transform: scale(1.05); }
        
        .stop-btn { background-color: var(--text-primary); color: var(--bg-color); }
        .stop-btn:hover { opacity: 0.8; }

        /* Input Mode Dropdown Classes */
        .input-mode-container { position: relative; display: flex; align-items: center; }
        .input-mode-btn {
            display: flex; align-items: center; gap: 6px; padding: 6px 12px;
            background: var(--bg-color); border: 1px solid var(--border-light);
            border-radius: 20px; font-size: 13px; font-weight: 600;
            color: var(--text-secondary); cursor: pointer; transition: all 0.2s;
