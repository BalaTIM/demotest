        /* Typing & Loading Indicators */
        .streaming-cursor::after { content: ''; display: inline-block; width: 8px; height: 16px; background-color: var(--text-primary); animation: blink 1s step-end infinite; margin-left: 4px; vertical-align: middle; border-radius: 2px;}
