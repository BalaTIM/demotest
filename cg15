        async function streamAIResponse(userPromptContext) {
            setStopMode();
            const ts = getTimestamp();

            const row = document.createElement('div');
            row.className = 'message-row assistant';
            const bubble = document.createElement('div');
            bubble.className = 'assistant-response streaming-cursor';
            row.appendChild(bubble);
            chatContainer.appendChild(row);
            scrollArea.scrollTo({ top: scrollArea.scrollHeight, behavior: 'smooth' });

            abortController = new AbortController();
            let fullText = '';
            
            try {
                // FIXED PAYLOAD: Stripped strict parameters (like temperature & max_tokens) 
                // so reasoning models like DeepSeek can use native server defaults.
                const payload = {
                    model: currentModel,
                    messages: conversationHistory.map(m => ({ role: m.role, content: String(m.text) })),
                    stream: true
                };

                const response = await fetch(GROQ_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${API_KEY}` },
                    body: JSON.stringify(payload),
                    signal: abortController.signal
                });

                if (!response.ok) {
                    const errText = await response.text();
                    let errMsg = `API Error ${response.status}`;
                    try {
                        const errJson = JSON.parse(errText);
                        if (errJson.error && errJson.error.message) errMsg += `: ${errJson.error.message}`;
                    } catch(e) {
                        errMsg += ` - ${errText}`;
                    }
                    throw new Error(errMsg);
                }
                
                const reader = response.body.getReader();
                const decoder = new TextDecoder('utf-8');
                let buffer = '';

                while (true) {
                    const { done, value } = await reader.read();
                    if (done) break;
                    buffer += decoder.decode(value, { stream: true });
                    const lines = buffer.split('\n');
                    buffer = lines.pop();

                    for (const line of lines) {
                        const trimmed = line.trim();
                        if (!trimmed || !trimmed.startsWith('data:')) continue;
                        const jsonStr = trimmed.slice(5).trim();
                        if (jsonStr === '[DONE]') break;
                        try {
                            const parsed = JSON.parse(jsonStr);
                            const delta  = parsed.choices?.[0]?.delta?.content;
                            if (delta) {
                                fullText += delta;
                                bubble.innerHTML = marked.parse(fullText);
                                scrollArea.scrollTo({ top: scrollArea.scrollHeight });
                            }
                        } catch (e) {}
                    }
                }
            } catch (err) {
                // If user clicks "New Chat" mid-stream, silently exit to avoid DOM corruption
                if (isResetting) return; 
                
                if (err.name === 'AbortError') fullText = fullText || '*(Generation stopped)*';
                else fullText = `**Critical Error:**\n\n\`\`\`text\n${err.message}\n\`\`\``;
            }

            // Ensure we haven't initiated a UI reset while catching the error
            if (isResetting) return;

            bubble.classList.remove('streaming-cursor');
            bubble.innerHTML = marked.parse(fullText || '*(empty)*');
            formatCodeBlocks(bubble);
            
            // Smart Enhancements post-stream
            checkSmartUtilities(userPromptContext, fullText, bubble);
            
            row.appendChild(createActionBar(fullText));
            const timeDiv = document.createElement('div');
            timeDiv.className = 'msg-timestamp';
            timeDiv.textContent = ts;
            row.appendChild(timeDiv);
            
            // Launch dynamic content engine after response
            await appendDynamicSuggestions(userPromptContext, row);

            scrollArea.scrollTo({ top: scrollArea.scrollHeight, behavior: 'smooth' });
            
            conversationHistory.push({ role: 'assistant', text: fullText, timestamp: ts });
            localStorage.setItem('chots_conversation', JSON.stringify(conversationHistory));
            setSendMode();
        }

        function handleSend() {
            const text = inputField.value.trim();
            if ((!text && pendingFiles.length === 0) || isStreaming) return;

            document.body.classList.add('chat-active');
            
            const ts = getTimestamp();
            let fileContextStr = "";
            let filesHtml = "";

            if (pendingFiles.length > 0) {
                fileContextStr = pendingFiles.map(f => `[Attached file: ${f.file.name}]`).join('\n');
                filesHtml = `<div style="display:flex; gap:8px; margin-bottom:8px; flex-wrap:wrap;">` + 
                    pendingFiles.map(f => `<div style="padding:6px 12px; background:var(--bg-color); border:1px solid var(--border-light); border-radius:8px; font-size:12px; font-weight:600; display:flex; align-items:center; gap:6px;"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z\"></path><polyline points=\"13 2 13 9 20 9\"></polyline></svg> ${f.file.name}</div>`).join('') +
                    `</div>`;
            }

            _renderUserMessage(text, filesHtml, ts);
            
            // FIXED: Prevent trailing space creation if only attaching files
            const aiPrompt = text + (text && fileContextStr ? '\n\n' : '') + fileContextStr;
            
            conversationHistory.push({ role: 'user', text: aiPrompt, timestamp: ts });
            localStorage.setItem('chots_conversation', JSON.stringify(conversationHistory));

            inputField.value = '';
            inputField.style.height = 'auto';
            pendingFiles = [];
            filePreviewArea.innerHTML = '';
            setSendMode();

            addLoadingIndicator();
            setTimeout(() => {
                removeLoadingIndicator();
                streamAIResponse(aiPrompt);
            }, 400);
        }

        // ============================================================
        //  FILE & INPUT LOGIC
        // ============================================================
        attachBtn.addEventListener('click', () => fileUpload.click());
        fileUpload.addEventListener('change', (e) => {
            Array.from(e.target.files).forEach(file => {
                pendingFiles.push({ file, isImage: file.type.startsWith('image/') });
            });
            renderFilePreviews();
            e.target.value = '';
            inputField.focus();
        });

        function renderFilePreviews() {
            filePreviewArea.innerHTML = '';
            pendingFiles.forEach((f, i) => {
                const item = document.createElement('div');
                item.className = 'file-preview-item';
                item.innerHTML = f.isImage ? `<img src="${URL.createObjectURL(f.file)}">` : `<div style="font-size:10px; padding:4px; text-align:center; word-break:break-all; color:var(--text-secondary);">${f.file.name}</div>`;
                const rm = document.createElement('button');
                rm.className = 'file-remove-btn'; rm.innerHTML = '×';
                rm.onclick = () => { pendingFiles.splice(i, 1); renderFilePreviews(); };
                item.appendChild(rm);
                filePreviewArea.appendChild(item);
            });
        }

        inputField.addEventListener('input', () => {
            inputField.style.height = 'auto';
            inputField.style.height = Math.min(inputField.scrollHeight, 200) + 'px';
            if (isStreaming) return;
            if (inputField.value.trim().length > 0 || pendingFiles.length > 0) {
                sendBtn.innerHTML = `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>`;
                sendBtn.onclick = handleSend;
            } else {
                setSendMode();
            }
        });
        inputField.addEventListener('keydown', e => {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); handleSend(); }
        });
        sendBtn.addEventListener('click', handleSend);

        // ============================================================
        //  GLOBAL EXPORT & CLEAR
        // ============================================================
        function resetConversation() {
            // Check if user is already on a blank chat (no history, no text, no files)
            if (conversationHistory.length === 0 && inputField.value.trim() === '' && pendingFiles.length === 0) {
                if (window.innerWidth <= 768) closeSidebar();
                inputField.focus();
                return;
            }

            // Execute clear mechanism with safe confirmation if there is active history
            if (conversationHistory.length === 0 || confirm("Start a new chat? Current progress will be cleared.")) {
                
                isResetting = true; // Engage Stream Block
                if(abortController) abortController.abort(); // Terminate pending AI
                
                // Flush memory
                conversationHistory = [];
                localStorage.removeItem('chots_conversation');
                
                // DOM Wipe
                chatContainer.innerHTML = '';
                document.body.classList.remove('chat-active');
                
                // Input Wipe
                inputField.value = '';
                inputField.style.height = 'auto';
                pendingFiles = []; 
                renderFilePreviews();
                
                // State resets
                removeLoadingIndicator();
                setSendMode();
                
                // UI Management
                if (window.innerWidth <= 768) closeSidebar();
                
                // Safely reset block and focus
                setTimeout(() => {
                    isResetting = false;
                    inputField.focus();
                }, 100);
            }
        }
        
        clearChatBtn.addEventListener('click', resetConversation);
        newChatSidebarBtn.addEventListener('click', resetConversation);

        const exportModal = document.getElementById('export-modal');
        document.getElementById('global-share-btn').addEventListener('click', () => exportModal.classList.add('active'));
        document.getElementById('close-export-modal').addEventListener('click', () => exportModal.classList.remove('active'));

        function handleGlobalExport(type) {
            let text = conversationHistory.map(m => `${m.role === 'user' ? 'You' : 'Chots'} [${m.timestamp}]:\n${m.text}`).join('\n\n---\n\n');
            if(!text) { alert("Nothing to export."); return; }
            
            const fn = `Chots_Export_${Date.now()}`;
            if (type === 'txt') {
                const a = Object.assign(document.createElement('a'), { href: URL.createObjectURL(new Blob([text], { type: 'text/plain' })), download: `${fn}.txt` });
                a.click();
            } else if (type === 'pdf') {
                const { jsPDF } = window.jspdf; const doc = new jsPDF();
                const lines = doc.splitTextToSize(text, 180);
                let y = 10;
                lines.forEach(line => {
                    if (y > 280) { doc.addPage(); y = 10; }
                    doc.text(line, 10, y); y += 7;
                });
                doc.save(`${fn}.pdf`);
            }
            exportModal.classList.remove('active');
        }

        // Load History
        window.addEventListener('DOMContentLoaded', () => {
            const saved = localStorage.getItem('chots_conversation');
            if (saved) {
                try {
                    const parsed = JSON.parse(saved);
                    if (parsed && parsed.length > 0) {
                        document.body.classList.add('chat-active');
                        conversationHistory = parsed;
                        parsed.forEach(msg => {
                            if (msg.role === 'user') _renderUserMessage(msg.text, '', msg.timestamp);
                            else _renderAssistantMessage(msg.text, msg.timestamp);
                        });
                        setTimeout(() => scrollArea.scrollTo({ top: scrollArea.scrollHeight }), 100);
                    }
                } catch(e) {}
            }
        });
    </script>
</body>
</html>
