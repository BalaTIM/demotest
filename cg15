        .input-mode-item {
            display: flex; align-items: center; gap: 10px; padding: 10px 12px;
            border-radius: var(--radius-md); font-size: 13px; font-weight: 500;
            color: var(--text-primary); cursor: pointer; transition: background 0.2s;
