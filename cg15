                            <div class="dynamic-thumb" style="background: linear-gradient(135deg, hsl(${hue1}, 65%, 45%), hsl(${hue2}, 75%, 25%));">
                                ${keyword}
                            </div>
                            <div class="play-icon"><svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg></div>
                            <div class="card-content">
                                <div class="card-title">Top tutorials on "${keyword}"</div>
                                <div class="card-desc">YouTube Search Results</div>
                            </div>
                        </a>
                    </div>
                `;
                wrap.appendChild(videoSection);
            }

            // 2. DYNAMIC WEB ARTICLES (via Wikipedia Public API)
            if (document.getElementById('toggle-links').checked) {
                const linkSection = document.createElement('div');
                linkSection.className = 'suggestion-section';
                const gridId = `wiki-grid-${Date.now()}`;
                linkSection.innerHTML = `<h4><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg> Web Articles</h4><div class="suggestion-grid" id="${gridId}">Loading...</div>`;
                wrap.appendChild(linkSection);

                try {
                    // Fetch real related articles from Wikipedia without API keys
                    const res = await fetch(`https://en.wikipedia.org/w/api.php?action=opensearch&search=${encodedKeyword}&limit=2&namespace=0&format=json&origin=*`);
                    const data = await res.json();
                    
                    const titles = data[1];
                    const links = data[3];

                    let linksHtml = '';
                    if (titles && titles.length > 0) {
                        for(let i=0; i<titles.length; i++) {
                            linksHtml += `
                            <a href="${links[i]}" target="_blank" class="suggestion-card link-card">
                                <svg class="card-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                                <div class="card-title">${titles[i]}</div>
                                <div class="card-desc">Wikipedia Resource</div>
                            </a>`;
                        }
                    } else {
                        // Fallback to Google Search if Wikipedia has no exact matches
                        linksHtml = `
                        <a href="https://www.google.com/search?q=${encodedKeyword}" target="_blank" class="suggestion-card link-card">
                            <svg class="card-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line></svg>
